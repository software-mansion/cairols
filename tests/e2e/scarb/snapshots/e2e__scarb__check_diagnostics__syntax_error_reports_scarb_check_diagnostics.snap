          character: 9
      severity: 2
      code: E0001
      message: Unused variable. Consider ignoring by prefixing with `_`.
  - related_code: ''
    diagnostic:
      range:
        start:
          line: 1
          character: 11
        end:
          line: 1
          character: 11
      severity: 1
      code: E1002
      message: Missing tokens. Expected an expression.
  - related_code: ''
    diagnostic:
      range:
        start:
          line: 1
          character: 11
        end:
          line: 1
          character: 11
      severity: 1
      code: E1001
